# Environment variables for the Interview-to-BPMN application

# For FastAPI Users authentication backend
# Generate a good secret with: openssl rand -hex 32
AUTH_SECRET="super_secret_key_replace_this_in_production_1234567890abcdef" # CHANGE THIS!
JWT_LIFETIME_SECONDS=3600 # 1 hour, example

# For sending emails (magic links) - MailHog for local dev
SMTP_HOST="localhost" # or your mail server
SMTP_PORT=1025 # MailHog default SMTP port
SMTP_USER="" # If auth needed
SMTP_PASSWORD="" # If auth needed
SMTP_FROM_EMAIL="noreply@interview-bpmn.example.com"
SMTP_FROM_NAME="Interview-to-BPMN"

# Database URL (already used by Alembic, could be centralized here too)
# DATABASE_URL="sqlite:///./interview_bpmn.db" # Handled in app/db.py for now

# Admin user for seeding (if seed script uses .env)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme" # Seed script should hash this

# Application settings
APP_BASE_URL="http://localhost:8000" # Used for generating magic links

# Add other environment-specific configurations here
# Example: LOG_LEVEL=INFO
# Example: CORS_ORIGINS="http://localhost:3000,http://localhost:8000" # If frontend is separate origin
# For now, assuming same-origin or FastAPI default CORS (allow all for dev)
# Will configure CORS properly in main.py if needed.
